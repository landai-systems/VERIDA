{
  "name": "verida-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "VERIDA — Proof-of-Human Social Web frontend",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",

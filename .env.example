# ── Application ────────────────────────────────────────────────────────────────
# Runtime environment: development | staging | production
ENVIRONMENT=development

# FastAPI secret key — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Production release gate — MUST be set manually by a human operator in prod
# PROD_RELEASE_APPROVED=explicit-human-signoff

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://verida:verida@localhost:5432/verida
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────────────────────
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
# Algorithm for JWT signing
JWT_ALGORITHM=HS256

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email / Mailpit ────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@verida.local

# ── Observability ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Optional: OTEL collector endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Feature flags ────────────────────────────────────────────────────────────────
# Enable/disable content authenticity heuristics
ENABLE_AUTHENTICITY_CHECK=true
